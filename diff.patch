+/* -- TCP Connection Management Function (from main.c1) --------------------- */
+void TCP_Task(void)
+{
+    uint8_t status = W5500_GetSocketStatus(0);
+    if (status == 0x17)
+    {
+        g_eth_ok = 1;
+        health_set_tcp(HEALTH_OK);
+    }
+    else
+    {
+        g_eth_ok = 0;
+        health_set_tcp(HEALTH_FAIL);
+        // reconnect try
+        W5500_TCP_Client_Connect(0, server_ip, 5000);
+    }
+}
+
