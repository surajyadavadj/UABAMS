# .gitignore for React Native web/mobile frontend
# Maintained by: scratch
# Do not add project-wide ignores here — use root .gitignore

# ─── Dependencies ───────────────────────────────────────────
node_modules/
.pnp/
.pnp.js

# ─── Expo (if used) ─────────────────────────────────────────
.expo/
.expo-shared/
dist/
web-build/

# ─── Metro Bundler ──────────────────────────────────────────
.metro-health-check*

# ─── Build Output ───────────────────────────────────────────
build/

# ─── iOS ────────────────────────────────────────────────────
ios/Pods/
ios/build/
ios/*.xcarchive
ios/DerivedData/
ios/*.pbxuser
ios/*.mode1v3
ios/*.mode2v3
ios/*.perspectivev3
ios/xcuserdata/
ios/.xcode.env.local
*.hmap

# ─── Android ────────────────────────────────────────────────
android/app/build/
android/build/
android/.gradle/
android/local.properties
android/*.keystore
!android/debug.keystore          # debug keystore is safe to commit
android/app/google-services.json # contains API keys — never commit

# ─── Environment & Secrets ──────────────────────────────────
.env
.env.*
!.env.example                    # example template is safe and encouraged
google-services.json
GoogleService-Info.plist         # iOS Firebase config — contains keys

# ─── Testing ────────────────────────────────────────────────
coverage/
.jest/

# ─── TypeScript ─────────────────────────────────────────────
*.tsbuildinfo

# ─── Logs ───────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Misc ───────────────────────────────────────────────────
.cache/
.DS_Store
.next/
.nuxt/
*.local
.cache/
coverage/


