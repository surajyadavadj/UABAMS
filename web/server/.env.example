PORT=5000
NODE_ENV=development

# Database (PostgreSQL — new server src/app.js)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=railway_monitoring
DB_USER=admin
DB_PASSWORD=changeme

# CouchDB (server.js)
COUCHDB_HOST=127.0.0.1
COUCHDB_PORT=5984
COUCHDB_USER=admin
COUCHDB_PASS=changeme

# MQTT broker
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=sensor/railway

# CORS
CORS_ORIGIN=http://localhost:3000

# Thresholds
# Minimum peak_g to classify a reading as an impact event and write to accelerometer_events table.
# Severity levels (set by bridge): LOW > 2g | MEDIUM > 8g | HIGH > 16g
# Sensible defaults:
#   0.01  — development/testing (captures all sensor activity)
#   0.10  — light vibration filter (filters near-zero noise)
#   2.00  — LOW severity threshold (real railway operations)
IMPACT_THRESHOLD=0.01
